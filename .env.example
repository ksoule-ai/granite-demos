# Copy to .env and fill in.
# Base URL of your Hugging Face Inference Endpoint, with /v1 appended.
# e.g. https://xxxxxxxx.us-east-1.aws.endpoints.huggingface.cloud/v1
HF_ENDPOINT_URL=

# A Hugging Face access token with permission to call the endpoint.
HF_TOKEN=

# Model id as reported by the endpoint's /v1/models (usually the repo id).
MODEL_ID=ibm-granite/granite-switch-4.1-3b-preview
